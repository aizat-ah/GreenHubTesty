rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isLoggedIn() { return request.auth != null; }
    function getRole() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role; }
    function hasSupplierAccess() { return isLoggedIn() && (getRole() == 'supplier' || getRole() == 'admin'); }
    function isAdminUser() { return isLoggedIn() && getRole() == 'admin'; }

    match /users/{userId} {
      allow read: if request.auth.uid == userId || hasSupplierAccess();
      allow create: if request.auth.uid == userId || isAdminUser();
      allow update: if request.auth.uid == userId || isAdminUser();
      allow delete: if isAdminUser();
    }
    match /products/{productId} {
      allow read: if isLoggedIn();
      allow write: if hasSupplierAccess();
    }
    match /orders/{orderId} {
      allow create: if isLoggedIn();
      allow read: if isLoggedIn() && (resource.data.customerId == request.auth.uid || hasSupplierAccess());
      allow update: if hasSupplierAccess();
      allow delete: if hasSupplierAccess();
    }
  }
}